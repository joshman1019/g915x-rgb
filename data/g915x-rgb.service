[Unit]
Description=G915 X RGB - Keyboard lighting watcher
After=graphical-session.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 -m g915x_rgb.watcher
Environment=PYTHONPATH=/home/joshua/Development/g915x-rgb/src
Restart=on-failure
RestartSec=10

[Install]
WantedBy=graphical-session.target
